{
  "name": "github-pr-notifications",
  "version": "1.0.0",
  "description": "Browser notifications for GitHub PR CI status changes and comments, with PR bookmark syncing",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:zip": "node scripts/build.js --zip",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbmartin/chrome-extension-github-pr-notifications.git"
  },
  "license": "MIT",
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "vitest": "^3.2.6"
  }
}
